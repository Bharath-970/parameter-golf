    "mlp_mult": 3.0,
    "tie_embeddings": true,
    "qk_gain_init": 5.25,
    "rope_dims": 16,
    "xsa_all": true,
    "recur_start": 4,
    "recur_end": 7,
    "parallel_residuals": true
