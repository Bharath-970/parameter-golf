    "EMA (Exponential Moving Average) for quantization-aware checkpoints",
    "Self-Generated GPTQ Calibration (Activation-aware scaling)",
    "Score-first causal TTT on last 3 layers",
    "Parallel Residuals (PaLM-style)",
    "Depth Recurrence (Blocks 4-6 repeating once)",
    "Partial RoPE (rope_dims=16)"
  ],
  "architecture": {
    "vocab_size": 8192,
    "num_layers": 11,
    "model_dim": 512,
    "num_heads": 8,
